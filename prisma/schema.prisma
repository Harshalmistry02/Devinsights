generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  username          String?            @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  accounts          Account[]
  analyticsSnapshot AnalyticsSnapshot?
  insightCaches     InsightCache[]
  repositories      Repository[]
  sessions          Session[]
  syncCheckpoint    SyncCheckpoint?
  syncJobs          SyncJob[]
  aiUsage           AiUsage[]

  @@index([createdAt])
  @@map("users")
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Repository {
  id            String    @id @default(cuid())
  userId        String
  githubId      Int
  name          String
  fullName      String
  description   String?
  language      String?
  stars         Int       @default(0)
  forks         Int       @default(0)
  isPrivate     Boolean   @default(false)
  isFork        Boolean   @default(false)
  isArchived    Boolean   @default(false)
  defaultBranch String    @default("main")
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  commits       Commit[]
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, githubId])
  @@index([userId])
  @@index([lastSyncedAt(sort: Desc)])
  @@map("repositories")
}

model Commit {
  id           String     @id @default(cuid())
  repositoryId String
  sha          String
  message      String     @db.Text
  authorName   String?
  authorEmail  String?
  authorDate   DateTime
  additions    Int        @default(0)
  deletions    Int        @default(0)
  filesChanged Int        @default(0)
  createdAt    DateTime   @default(now())
  metadata     Json?
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, sha])
  @@index([repositoryId])
  @@index([authorDate(sort: Desc)])
  @@index([repositoryId, authorDate(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("commits")
}

model SyncJob {
  id             String     @id @default(cuid())
  userId         String
  status         SyncStatus @default(PENDING)
  totalRepos     Int        @default(0)
  processedRepos Int        @default(0)
  totalCommits   Int        @default(0)
  errorMessage   String?
  startedAt      DateTime   @default(now())
  completedAt    DateTime?
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("sync_jobs")
}

model AnalyticsSnapshot {
  id                   String         @id @default(cuid())
  userId               String         @unique
  totalRepos           Int            @default(0)
  totalCommits         Int            @default(0)
  totalAdditions       Int            @default(0)
  totalDeletions       Int            @default(0)
  totalStars           Int            @default(0)
  totalForks           Int            @default(0)
  currentStreak        Int            @default(0)
  longestStreak        Int            @default(0)
  lastCommitDate       DateTime?
  isActiveToday        Boolean        @default(false)
  languageStats        Json?
  dailyCommits         Json?
  dayOfWeekStats       Json?
  hourlyStats          Json?
  repoStats            Json?
  topLanguages         Json?
  averageCommitsPerDay Float          @default(0)
  mostProductiveDay    String?
  mostProductiveHour   Int?
  calculatedAt         DateTime       @default(now())
  dataRangeStart       DateTime?
  dataRangeEnd         DateTime?
  commitQualityMetrics Json?
  codeImpactMetrics    Json?
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  generatedInsights    InsightCache[]

  @@index([userId])
  @@index([calculatedAt])
  @@map("analytics_snapshots")
}

model InsightCache {
  id         String            @id @default(cuid())
  userId     String
  snapshotId String
  dataHash   String
  insights   Json
  model      String?
  tokensUsed Int?
  createdAt  DateTime          @default(now())
  expiresAt  DateTime
  snapshot   AnalyticsSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dataHash])
  @@index([userId])
  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("insight_caches")
}

model SyncCheckpoint {
  userId                String     @id
  lastProcessedRepoId   String?
  lastProcessedCommitId String?
  lastProcessedCommitSha String?
  lastSyncTimestamp     DateTime   @default(now()) @updatedAt
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sync_checkpoints")
}

model AiUsage {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime @db.Date
  tokensUsed    Int      @default(0)
  requestsCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("ai_usage")
}

enum SyncStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}
